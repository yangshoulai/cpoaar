{
  "manifest_version": 3,
  "name": "Auto Register Console",
  "description": "在 Chrome Side Panel 中配置、观察并执行注册自动化流程。",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Auto Register",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/ui/sidepanel.html"
  },
  "permissions": [
    "activeTab",
    "cookies",
    "sidePanel",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://auth.openai.com/*",
    "https://*.openai.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "<all_urls>"
  ]
}
